#!/usr/bin/env bash
# ox-pool — start a pool of ox-runner processes in seguro VMs
#
# Usage:
#   ox-pool start 3                  # start 3 runners
#   ox-pool start 3 --local          # start 3 runners as local processes (no seguro)
#   OX_SERVER=http://host:4840 ox-pool start 5
#
# Environment:
#   OX_SERVER        ox-server URL (required)
#   OX_BIN           path to ox binaries (default: directory containing this script)
#   OX_RUNNERS_DIR   base directory for runner workspaces (default: /tmp/ox-runners)
#   OX_ENVIRONMENT   environment label (default: seguro, or local with --local)

set -euo pipefail

OX_BIN="${OX_BIN:-$(cd "$(dirname "$0")" && pwd)}"
OX_RUNNERS_DIR="${OX_RUNNERS_DIR:-/tmp/ox-runners}"
OX_SERVER="${OX_SERVER:-http://localhost:4840}"
OX_ENVIRONMENT="${OX_ENVIRONMENT:-seguro}"

usage() {
    echo "usage: ox-pool <command> [args]"
    echo ""
    echo "commands:"
    echo "  start <n> [--local]   Start n runners (--local skips seguro)"
    echo "  stop                  Stop all runners started by this script"
    echo "  status                Show running runners"
    echo ""
    echo "environment:"
    echo "  OX_SERVER       ox-server URL (default: http://localhost:4840)"
    echo "  OX_BIN          path to ox binaries (default: script directory)"
    echo "  OX_RUNNERS_DIR  workspace base dir (default: /tmp/ox-runners)"
    exit 1
}

PIDFILE="${OX_RUNNERS_DIR}/.ox-pool.pids"

start_local_runner() {
    local id=$1
    local work_dir="${OX_RUNNERS_DIR}/runner-${id}"
    mkdir -p "$work_dir"

    OX_SERVER="$OX_SERVER" \
    OX_ENVIRONMENT="${OX_ENVIRONMENT}" \
    OX_WORKSPACE_DIR="$work_dir" \
        "${OX_BIN}/../target/debug/ox-runner" \
        --server "$OX_SERVER" \
        --environment "$OX_ENVIRONMENT" \
        --workspace-dir "$work_dir" \
        &>"${work_dir}/runner.log" &

    local pid=$!
    echo "$pid" >> "$PIDFILE"
    echo "  runner $id: pid=$pid workspace=$work_dir"
}

start_seguro_runner() {
    local id=$1
    local work_dir="${OX_RUNNERS_DIR}/runner-${id}"
    mkdir -p "$work_dir"

    seguro run \
        --share "${OX_BIN}:/ox:ro" \
        --share "${work_dir}:/work:rw" \
        --env OX_SERVER="$OX_SERVER" \
        --env OX_ENVIRONMENT=seguro \
        --env OX_WORKSPACE_DIR=/work \
        --env PATH="/ox/bin:\$PATH" \
        -- /ox/bin/ox-runner \
        &>"${work_dir}/runner.log" &

    local pid=$!
    echo "$pid" >> "$PIDFILE"
    echo "  runner $id: pid=$pid (seguro) workspace=$work_dir"
}

cmd_start() {
    local count="${1:-1}"
    local mode="seguro"

    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --local) mode="local"; OX_ENVIRONMENT="local" ;;
            *) echo "unknown flag: $1" >&2; exit 1 ;;
        esac
        shift
    done

    mkdir -p "$OX_RUNNERS_DIR"
    > "$PIDFILE"  # truncate

    echo "starting $count runners (mode=$mode, server=$OX_SERVER)"

    for i in $(seq 1 "$count"); do
        if [[ "$mode" == "local" ]]; then
            start_local_runner "$i"
        else
            start_seguro_runner "$i"
        fi
    done

    echo "pool started. pids in $PIDFILE"
    echo "logs in $OX_RUNNERS_DIR/runner-*/runner.log"
}

cmd_stop() {
    if [[ ! -f "$PIDFILE" ]]; then
        echo "no pool running (no pidfile at $PIDFILE)"
        return
    fi

    echo "stopping runners..."
    while read -r pid; do
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null && echo "  killed $pid" || true
        fi
    done < "$PIDFILE"

    rm -f "$PIDFILE"

    # Clean up workspace dirs
    if [[ -d "$OX_RUNNERS_DIR" ]]; then
        rm -rf "${OX_RUNNERS_DIR}"/runner-*
        echo "cleaned up workspaces"
    fi
}

cmd_status() {
    if [[ ! -f "$PIDFILE" ]]; then
        echo "no pool running"
        return
    fi

    local alive=0
    local dead=0
    while read -r pid; do
        if kill -0 "$pid" 2>/dev/null; then
            echo "  runner pid=$pid alive"
            alive=$((alive + 1))
        else
            dead=$((dead + 1))
        fi
    done < "$PIDFILE"

    echo "$alive alive, $dead dead"
}

# ── Main ─────────────────────────────────────────────────────────────

if [[ $# -lt 1 ]]; then
    usage
fi

command="$1"; shift

case "$command" in
    start)  cmd_start "$@" ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    *)      usage ;;
esac
