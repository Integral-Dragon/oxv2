#!/usr/bin/env bash
# ox-rt — runtime interface helper
# Usage: ox-rt done pass
#        ox-rt done pass:7
#        ox-rt done --force pass            # skip pre-flight checks
#        ox-rt metric input_tokens 14523
#        echo "content" | ox-rt artifact proposal
#        ox-rt artifact-done proposal

set -euo pipefail

if [ -z "${OX_SOCKET:-}" ]; then
  echo "error: OX_SOCKET not set" >&2
  exit 1
fi

if [ $# -lt 1 ]; then
  echo "usage: ox-rt <command> [args...]" >&2
  echo "commands: done, metric, artifact, artifact-done" >&2
  exit 1
fi

cmd="$1"; shift

# Strip --force from args; remember whether it was set.
force=0
new_args=()
for arg in "$@"; do
  case "$arg" in
    --force) force=1 ;;
    *) new_args+=("$arg") ;;
  esac
done
if [ ${#new_args[@]} -gt 0 ]; then
  set -- "${new_args[@]}"
else
  set --
fi

send() {
  local msg="$1"
  local resp
  resp=$(python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.connect('$OX_SOCKET')
s.sendall(('$msg' + '\n').encode())
data = s.recv(4096)
s.close()
sys.stdout.write(data.decode())
" 2>/dev/null) || {
    echo "error: failed to connect to $OX_SOCKET" >&2
    exit 1
  }
  if [[ "$resp" == error:* ]]; then
    echo "$resp" >&2
    exit 1
  fi
}

# Pre-flight for `done`: refuse if the work isn't actually on origin.
# The next workflow step does a fresh clone of origin/$branch — anything
# uncommitted, unpushed, or absent from the remote is invisible to it.
preflight_done() {
  git rev-parse --git-dir >/dev/null 2>&1 || return 0

  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0
  if [ "$branch" = "HEAD" ] || [ "$branch" = "main" ]; then
    return 0
  fi

  if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
    cat >&2 <<EOF
error: ox-rt done refused — working tree is dirty.

You have uncommitted changes in $(pwd). The next step clones a fresh
workspace from origin and will never see them. Commit and push:

    git add <files>
    git commit -m "..."
    git push origin $branch

Then re-run \`ox-rt done <output>\`. If you really mean to abandon
these changes, re-run with --force:

    ox-rt done --force <output>
EOF
    return 1
  fi

  git fetch origin "$branch" >/dev/null 2>&1 || true
  git fetch origin main >/dev/null 2>&1 || true

  local local_head remote_head
  local_head=$(git rev-parse HEAD)
  remote_head=$(git rev-parse --verify "origin/$branch" 2>/dev/null || echo "")

  if [ -z "$remote_head" ]; then
    cat >&2 <<EOF
error: ox-rt done refused — origin/$branch does not exist.

Branch '$branch' has not been pushed to origin. The next step clones
from origin and will never see your work. Push:

    git push origin $branch

Then re-run \`ox-rt done <output>\`. If you really mean to report done
without pushing, re-run with --force.
EOF
    return 1
  fi

  if [ "$local_head" != "$remote_head" ]; then
    local ahead
    ahead=$(git rev-list --count "origin/$branch..HEAD" 2>/dev/null || echo "?")
    cat >&2 <<EOF
error: ox-rt done refused — local HEAD is ahead of origin/$branch by $ahead commit(s).

Your push did not happen, or did not reach the remote. The next step
clones from origin/$branch and will never see these commits. Push:

    git push origin $branch

Then re-run \`ox-rt done <output>\`. If you really mean to report done
without pushing, re-run with --force.
EOF
    return 1
  fi

  local ahead_of_main
  ahead_of_main=$(git rev-list --count "origin/main..origin/$branch" 2>/dev/null || echo "0")
  if [ "$ahead_of_main" -eq 0 ]; then
    cat >&2 <<EOF
error: ox-rt done refused — origin/$branch has no commits ahead of origin/main.

There is nothing on this branch for the next step to review. You may
have committed and pushed to the wrong branch, or never committed at
all. Investigate, then re-run \`ox-rt done <output>\`.

If you really mean to report done with no work to show, re-run with
--force.
EOF
    return 1
  fi

  return 0
}

case "$cmd" in
  done)
    if [ "$force" -ne 1 ]; then
      preflight_done || exit 1
    fi
    send "done $*"
    ;;
  metric)
    send "metric $*"
    ;;
  artifact)
    name="$1"; shift
    if [ $# -gt 0 ]; then
      data=$(echo -n "$*" | base64 -w0)
    else
      data=$(base64 -w0)
    fi
    send "artifact $name $data"
    ;;
  artifact-done)
    send "artifact-done $1"
    ;;
  *)
    echo "error: unknown command: $cmd" >&2
    exit 1
    ;;
esac
